# Cloudflare Turnstile Environment Variables
# Replace these with your actual keys from the Cloudflare dashboard

# The site key is used on the client side to render the Turnstile widget
# This key is safe to expose in client-side code
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=0x4AAAAAABNca5oH8hytZ4AN

# The secret key is used on the server side to verify the captcha token
# This key must be kept secret and only used in server-side code
CLOUDFLARE_TURNSTILE_SECRET_KEY=0x4AAAAAABNca0LsTrOYWe0bHHTLHZ8KFzw


# Additional environment variables for your application
# Add any other environment variables your application needs below
